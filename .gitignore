node_modules/
dist/
# JELA-67: the built Lite blob is committed — the server plugin embeds it
# as the /shell/lite.min.js resource (same pattern as shell-tizen's
# committed shell.min.js). dist-freshness.test.cjs guards staleness.
!packages/jellyplug-lite/dist/
packages/jellyplug-lite/dist/*
!packages/jellyplug-lite/dist/lite.min.js
build/
.turbo/
*.tsbuildinfo

# Tizen / webOS / Android build outputs
*.wgt
*.wgt.placeholder
*.ipk
*.ipk.placeholder
*.apk
*.apk.placeholder
.buildResult/
local.properties
.gradle/

# Pre-built release artifacts checked in until CI signing is wired up.
!release-artifacts/**/*.wgt

# IDEs
.vscode/
.idea/
*.iml

# OS noise
.DS_Store
Thumbs.db

# Build-script byproducts
__pycache__/
*.eb_clean

# Secrets - never commit
*.p12
keystore/
.env
.env.*
!.env.example
