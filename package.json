{
  "name": "jellyfin-tv-shell",
  "version": "0.0.0",
  "private": true,
  "description": "Thin browser-shell apps for Jellyfin on TV (Tizen / webOS / Android TV). Loads the live Jellyfin web client so server plugins work 1:1.",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jellyfin/jellyfin-tv.git"
  },
  "scripts": {
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "tsc --build",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  }
}
