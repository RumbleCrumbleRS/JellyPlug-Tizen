{
  "name": "jellyplug-tizen",
  "version": "0.0.0",
  "private": true,
  "description": "Thin browser-shell app for Jellyfin on Samsung Tizen TVs. Loads the live Jellyfin web client so server plugins work 1:1.",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RumbleCrumbleRS/JellyPlug-Tizen.git"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "esbuild": "0.21.5",
    "prettier": "^3.3.3"
  }
}
